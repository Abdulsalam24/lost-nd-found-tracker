# Database
DATABASE_URL=postgresql://lostfound:lostfound_dev@localhost:5432/lostfound_db

# JWT
JWT_SECRET=your-secret-here-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudflare R2 (use MinIO locally)
